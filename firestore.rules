rules_version = '2';

// =============================================================================
//  Firestore security rules for the Boosted web-design Client Manager.
//
//  IMPORTANT — this repo deploys HOSTING ONLY. These rules are NOT deployed by
//  this repo's CI. Apply them in the Firebase project that holds your client
//  data:
//    • Dedicated project (recommended): paste this file in as the whole ruleset.
//    • Reusing the Boosted app project (boosted-2c2a6): MERGE the two
//      `match` blocks below into that project's existing firestore.rules and
//      deploy from wherever those rules live.
//
//  Set OWNER_EMAILS to the address(es) you sign in to /admin/ with.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Add the email(s) you log into the Client Manager with ----
    function isOwner() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'owner@example.com'
        ];
    }

    // ---- Client records: owner only ----
    match /webClients/{clientId} {
      allow read, write: if isOwner();
    }

    // ---- Public edit-request inbox ----
    //  Anyone may SUBMIT a request (validated). Only the owner can read it back,
    //  mark it handled, or delete it.
    match /editRequests/{requestId} {
      allow read, update, delete: if isOwner();
      allow create: if isValidRequest();
    }

    function isValidRequest() {
      let d = request.resource.data;
      return d.keys().hasOnly(
               ['business', 'name', 'email', 'details', 'link', 'status', 'createdAt'])
        && d.business is string && d.business.size() > 0 && d.business.size() <= 120
        && d.name is string && d.name.size() <= 120
        && d.email is string && d.email.size() <= 200
        && d.details is string && d.details.size() > 0 && d.details.size() <= 4000
        && d.link is string && d.link.size() <= 500
        && d.status == 'open'
        && d.createdAt == request.time;
    }
  }
}
